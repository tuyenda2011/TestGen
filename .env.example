OLLAMA_CHAT_URL=http://localhost:11434/api/chat
OLLAMA_EMBED_URL=http://localhost:11434/api/embeddings
OPENROUTER_CHAT_URL=https://openrouter.ai/api/v1/chat/completions

OLLAMA_REQUIREMENT_MODEL=qwen2.5:7b
OLLAMA_TEST_PLANNING_MODEL=llama3.1:8b
OLLAMA_CODE_GENERATOR_MODEL=qwen2.5-coder:7b
OLLAMA_CODE_REVIEW_MODEL=deepseek-coder:6.7b
EMBED_MODEL=nomic-embed-text

GEMINI_REQUIREMENT_MODEL=gemini-2.0-flash
GEMINI_TEST_PLANNING_MODEL=gemini-2.0-flash
GEMINI_CODE_GENERATOR_MODEL=gemini-2.0-flash
GEMINI_CODE_REVIEW_MODEL=gemini-2.0-flash
GEMINI_EMBED_MODEL=gemini-embedding-001

CHUNK_SIZE=800
CHUNK_OVERLAP=100
TOP_K=4
REQUIREMENT_CONTEXT_BUDGET=9000
PLANNING_CONTEXT_BUDGET=8000
GENERATION_CONTEXT_BUDGET=8000
REVIEW_CONTEXT_BUDGET=8000

PYTEST_COVERAGE_THRESHOLD=80
PYTEST_MAX_ATTEMPTS=3
PYTEST_FUNCTION_BATCH_SIZE=4
PIPELINE_MAX_WORKERS=2
GENERATOR_MAX_WORKERS=5

OUTPUT_DIR=outputs
RUNTIME_DIR=.runtime
DOC_COLLECTION_NAME=testgen_chatbot_documents
SOURCE_COLLECTION_NAME=testgen_chatbot_source_code

# Do not commit real keys. Paste them in Streamlit sidebar or export locally.
# GEMINI_API_KEY=
