{
	"info": {
		"name": "Local Inventory API",
		"description": "A local API to manage inventory. Contains tricky auth and validation logic.",
		"schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
	},
	"item": [
		{
			"name": "1. Add Item",
			"request": {
				"method": "POST",
				"header": [
					{
						"key": "Content-Type",
						"value": "application/json"
					}
				],
				"body": {
					"mode": "raw",
					"raw": "{\n  \"name\": \"Laptop\",\n  \"quantity\": 10,\n  \"price\": 999.99\n}"
				},
				"url": {
					"raw": "http://localhost:8000/items",
					"protocol": "http",
					"host": [
						"localhost"
					],
					"port": "8000",
					"path": [
						"items"
					]
				},
				"description": "Adds a new item. Tricky: \n- Fails with 400 if quantity < 0.\n- Fails with 409 if name already exists."
			},
			"response": []
		},
		{
			"name": "2. Get Item",
			"request": {
				"method": "GET",
				"header": [],
				"url": {
					"raw": "http://localhost:8000/items/1",
					"protocol": "http",
					"host": [
						"localhost"
					],
					"port": "8000",
					"path": [
						"items",
						"1"
					]
				},
				"description": "Gets an item by ID. Returns 404 if not found."
			},
			"response": []
		},
		{
			"name": "3. Checkout Item",
			"request": {
				"method": "POST",
				"header": [
					{
						"key": "Content-Type",
						"value": "application/json"
					},
					{
						"key": "Authorization",
						"value": "Bearer secret-token"
					}
				],
				"body": {
					"mode": "raw",
					"raw": "{\n  \"amount\": 2\n}"
				},
				"url": {
					"raw": "http://localhost:8000/items/1/checkout",
					"protocol": "http",
					"host": [
						"localhost"
					],
					"port": "8000",
					"path": [
						"items",
						"1",
						"checkout"
					]
				},
				"description": "Checks out an item. Tricky:\n- Requires 'Bearer secret-token'. Returns 401 if missing, 403 if invalid.\n- Returns 400 if 'amount' > current quantity."
			},
			"response": []
		}
	]
}
